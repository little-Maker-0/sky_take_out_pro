          <boolProp name="ViewResultsTree.showFileBlockDevice">true</boolProp>
          <boolProp name="ViewResultsTree.showFileUnknown">true</boolProp>
        </ViewResultsTree>
        <hashTree/>
        <AggregateReport guiclass="AggregateReportGui" testclass="AggregateReport" testname="聚合报告" enabled="true">
          <boolProp name="AggregateReport.showLabel">true</boolProp>
          <boolProp name="AggregateReport.showSamples">true</boolProp>
          <boolProp name="AggregateReport.showAverage">true</boolProp>
          <boolProp name="AggregateReport.showMedian">true</boolProp>
          <boolProp name="AggregateReport.show90%Line">true</boolProp>
          <boolProp name="AggregateReport.show95%Line">true</boolProp>
          <boolProp name="AggregateReport.show99%Line">true</boolProp>
          <boolProp name="AggregateReport.showMin">true</boolProp>
          <boolProp name="AggregateReport.showMax">true</boolProp>
          <boolProp name="AggregateReport.showError">true</boolProp>
          <boolProp name="AggregateReport.showThroughput">true</boolProp>
          <boolProp name="AggregateReport.showReceivedKBytesPerSec">true</boolProp>
          <boolProp name="AggregateReport.showSentKBytesPerSec">true</boolProp>
          <boolProp name="AggregateReport.includeSubResults">true</boolProp>
        </AggregateReport>
        <hashTree/>
        <GraphResults guiclass="GraphVisualizer" testclass="GraphResults" testname="图表结果" enabled="true">
          <boolProp name="GraphVisualizer.showSampleCount">true</boolProp>
          <boolProp name="GraphVisualizer.showAverage">true</boolProp>
          <boolProp name="GraphVisualizer.showMedian">true</boolProp>
          <boolProp name="GraphVisualizer.show90Line">true</boolProp>
          <boolProp name="GraphVisualizer.show95Line">true</boolProp>
          <boolProp name="GraphVisualizer.show99Line">true</boolProp>
          <boolProp name="GraphVisualizer.showMin">true</boolProp>
          <boolProp name="GraphVisualizer.showMax">true</boolProp>
          <boolProp name="GraphVisualizer.showError">true</boolProp>
          <boolProp name="GraphVisualizer.showThroughput">true</boolProp>
          <boolProp name="GraphVisualizer.showKBytesPerSec">true</boolProp>
          <boolProp name="GraphVisualizer.showConnectTime">true</boolProp>
          <boolProp name="GraphVisualizer.showLatency">true</boolProp>
          <boolProp name="GraphVisualizer.showIdleTime">true</boolProp>
          <boolProp name="GraphVisualizer.granularity">60000</boolProp>
        </GraphResults>
        <hashTree/>
        <SimpleDataWriter guiclass="SimpleDataWriter" testclass="SimpleDataWriter" testname="保存测试结果" enabled="true">
          <stringProp name="filename">mysql-performance-test-results.csv</stringProp>
          <boolProp name="append">false</boolProp>
          <boolProp name="onlySuccesses">false</boolProp>
          <boolProp name="bytes">false</boolProp>
          <boolProp name="annotate">false</boolProp>
        </SimpleDataWriter>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>