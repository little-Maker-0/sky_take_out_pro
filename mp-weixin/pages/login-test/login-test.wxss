.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.login-section {
  background-color: white;
  padding: 30rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.login-btn {
  background-color: #007AFF;
  color: white;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.clear-btn {
  background-color: #f0f0f0;
  color: #333;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 8rpx;
}

.result-section {
  background-color: white;
  padding: 30rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.result-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.info-section {
  background-color: white;
  padding: 30rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.info-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.info-text {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 15rpx;
  line-height: 1.5;
}